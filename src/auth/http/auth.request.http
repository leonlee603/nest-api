## Sign up a user
POST http://localhost:3000/auth/sign-up
Content-Type: application/json

{
  "name": "John Doe",
  "email": "john.doe@example.com",
  "password": "Password@1234"
}

## Sign in a user
POST http://localhost:3000/auth/sign-in
Content-Type: application/json

{
  "email": "john.doe@example.com",
  "password": "Password@1234"
}

## Refresh a token
POST http://localhost:3000/auth/refresh-token
Content-Type: application/json

{
  "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiI4NThhZjgyNC0wZjU5LTQ2OWQtOTdkNy1mZGY1MDljMTc3OTgiLCJpYXQiOjE3NzM4MjMxMTksImV4cCI6MTc3MzkwOTUxOSwiYXVkIjoibG9jYWxob3N0OjMwMDAiLCJpc3MiOiJsb2NhbGhvc3Q6MzAwMCJ9.EYD0KwJVDkJ4on-LzVuO_2Q3czKGttUeXCvKzmxzEQk"
}

## Sign out a user
POST http://localhost:3000/auth/sign-out
Content-Type: application/json
